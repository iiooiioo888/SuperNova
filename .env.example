# SuperHub 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ============ 应用配置 ============
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production
LOG_LEVEL=INFO

# ============ 数据库配置 ============
# PostgreSQL
DATABASE_URL=postgresql+asyncpg://superhub:secret@localhost:5432/superhub
PG_PASSWORD=secret

# MongoDB
MONGODB_URI=mongodb://localhost:27017/superhub

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# ============ Celery 配置 ============
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ============ 对象存储配置 ============
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=superhub-media

# ============ 监控配置 ============
GRAFANA_URL=http://localhost:3001
GRAFANA_PASSWORD=admin
PROMETHEUS_URL=http://localhost:9090

# ============ 代理配置（可选） ============
# PROXY_POOL_ENABLED=false
# PROXY_POOL_API_URL=https://your-proxy-provider.com/api

# ============ 其他配置 ============
# 媒体下载临时目录
MEDIA_TEMP_DIR=/tmp/superhub/media

# 任务超时设置（秒）
DEFAULT_TASK_TIMEOUT=600
MAX_TASK_RETRIES=3
